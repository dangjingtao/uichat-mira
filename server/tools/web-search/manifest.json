{
  "id": "web-search",
  "name": "Web Search",
  "description": "Search the public web and return a list of titles, links, and snippets.",
  "version": "1.0.0",
  "category": "tool",
  "tags": ["search", "web"],
  "author": "ui-chat-rag-tester",
  "parameters": {
    "type": "object",
    "required": ["query"],
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query"
      },
      "maxResults": {
        "type": "number",
        "description": "Maximum number of results to return",
        "default": 5,
        "minimum": 1,
        "maximum": 10
      }
    }
  },
  "runtime": {
    "type": "search",
    "engine": "duckduckgo",
    "maxResults": 5
  }
}
