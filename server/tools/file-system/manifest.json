{
  "id": "file-system",
  "name": "File System",
  "description": "Read, write, or list files within the allowed workspace directory.",
  "version": "1.0.0",
  "category": "tool",
  "tags": ["file", "io"],
  "author": "ui-chat-rag-tester",
  "parameters": {
    "type": "object",
    "required": ["operation", "path"],
    "properties": {
      "operation": {
        "type": "string",
        "enum": ["read", "write", "list"],
        "description": "File operation to perform"
      },
      "path": {
        "type": "string",
        "description": "Relative path inside the allowed workspace"
      },
      "content": {
        "type": "string",
        "description": "Content to write, required when operation is 'write'"
      },
      "encoding": {
        "type": "string",
        "description": "File encoding",
        "default": "utf-8"
      }
    }
  },
  "runtime": {
    "type": "filesystem",
    "baseDir": "data/tool-files",
    "allowedOperations": ["read", "write", "list"]
  }
}
