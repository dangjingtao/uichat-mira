{
  "manifest_version": 3,
  "name": "Mira Clipper",
  "version": "1.0.0",
  "description": "将网页剪藏到你的 Mira 个人工作台",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "identity"
  ],
  "host_permissions": [
    "http://localhost:*/",
    "http://127.0.0.1:*/"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "剪藏当前页面到 Mira"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "打开 Mira Clipper"
    }
  },
  "options_page": "options/options.html"
}
