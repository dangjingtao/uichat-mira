{
  "name": "@ui-chat-mira/docs-site",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "description": "Static documentation site for the project docs.",
  "scripts": {
    "build:index": "node ./scripts/build-docs-index.mjs",
    "dev": "pnpm build:index && vite --host 127.0.0.1 --port 4280",
    "build": "pnpm build:index && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "marked": "^16.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
