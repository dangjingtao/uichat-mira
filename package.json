{
  "name": "ui-chat-rag-tester",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @ui-chat-rag-tester/desktop dev",
    "dev:all": "concurrently -k \"pnpm --filter @ui-chat-rag-tester/server dev\" \"pnpm --filter @ui-chat-rag-tester/desktop dev:no-backend\"",
    "build": "pnpm -r build",
    "check": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}