{
  "name": "ui-chat-rag-tester",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "author": "Tomz Dang <dangjingtao@gmail.com>",
  "description": "An initialization project for an Electron desktop application aimed at enterprise knowledge base verification, supporting dual-mode switching between local and remote models and vector databases.",
  "scripts": {
    "dev": "pnpm --filter @ui-chat-rag-tester/electron dev",
    "dev:server": "pnpm --filter @ui-chat-rag-tester/server dev",
    "dev:desktop": "pnpm --filter @ui-chat-rag-tester/desktop dev",
    "build": "pnpm build:desktop && pnpm build:server",
    "build:desktop": "pnpm --filter @ui-chat-rag-tester/desktop build",
    "build:server": "pnpm --filter @ui-chat-rag-tester/server build",
    "dist:mac": "node scripts/build-dist.js mac",
    "dist:win": "node scripts/build-dist.js",
    "check": "pnpm -r typecheck",
    "version:sync": "node scripts/sync-version.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "electron-builder": "^24.13.3",
    "electron": "31.7.7",
    "typescript": "^5.6.3"
  }
}