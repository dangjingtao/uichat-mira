{
  "name": "ui-chat-mira",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "author": "Tomz Dang <dangjingtao@gmail.com>",
  "description": "An intelligent agent cabin that starts with a chat and returns to your side.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dangjingtao/uichat-mira.git"
  },
  "homepage": "https://github.com/dangjingtao/uichat-mira",
  "appMeta": {
    "displayName": "UIChat Mira",
    "links": [
      {
        "label": "作者",
        "value": "Tomz Dang <dangjingtao@gmail.com>",
        "href": "https://github.com/dangjingtao"
      },
      {
        "label": "项目仓库",
        "value": "https://github.com/dangjingtao/uichat-mira.git",
        "href": "https://github.com/dangjingtao/uichat-mira"
      },
      {
        "label": "项目主页",
        "value": "https://github.com/dangjingtao/uichat-mira",
        "href": "https://github.com/dangjingtao/uichat-mira"
      },
      {
        "label": "组件文档",
        "value": "uchat / 内部 UI 组件",
        "href": "./docs/uchat.md"
      }
    ]
  },
  "scripts": {
    "dev:electron:win": "node scripts/generate-dev-coverage.js && pnpm --dir mira-clipper-ext dev && pnpm --filter @ui-chat-mira/electron dev",
    "dev:electron:win:trace": "cross-env AGENT_TRACE_PHOENIX=true PHOENIX_COLLECTOR_ENDPOINT=http://localhost:16006 AGENT_TRACE_PROJECT=uichat-mira-dev AGENT_TRACE_VERBOSE=true pnpm dev:electron:win",
    "dev:tauri:win": "pnpm --dir mira-clipper-ext dev && node scripts/run-tauri-dev.cjs",
    "docs:dev": "pnpm --filter @ui-chat-mira/docs-site dev",
    "docs:build": "pnpm --filter @ui-chat-mira/docs-site build",
    "package:electron:win": "node scripts/build-dist.js",
    "package:tauri:win": "node scripts/build-tauri-dist.js",
    "clean:artifacts": "node scripts/cleanup-artifacts.js",
    "check:no-db-in-index": "node scripts/check-no-db-in-index.js",
    "check": "pnpm -r --workspace-concurrency=1 typecheck",
    "check:tauri": "pnpm internal:prepare:tauri && cross-env CARGO_BUILD_JOBS=1 CARGO_INCREMENTAL=0 cargo check --manifest-path tauri/Cargo.toml -j 1",
    "version:sync": "node scripts/sync-version.js",
    "internal:build:desktop": "pnpm --filter @ui-chat-mira/desktop build",
    "internal:build:server": "pnpm --filter @ui-chat-mira/server build",
    "internal:prepare:desktop-artifacts": "node scripts/prepare-desktop-artifacts.js",
    "internal:prepare:tauri": "node scripts/prepare-tauri-assets.js",
    "internal:dev:tauri:services": "node scripts/tauri-dev-launcher.cjs",
    "prepare:piper-runtime": "node scripts/prepare-piper-runtime.mjs",
    "prepare:local-model-packs": "node scripts/prepare-local-model-packs.mjs",
    "archive:local-model-packs": "node scripts/archive-local-model-packs.mjs",
    "smoke:local-model-runtime": "node scripts/smoke-local-model-runtime.mjs",
    "eval:local-model-runtime": "node scripts/eval-local-model-runtime.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "@tauri-apps/cli": "^2.11.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1",
    "onnxruntime-web": "^1.27.0",
    "png2icons": "^2.0.1",
    "typescript": "^5.6.3"
  }
}
