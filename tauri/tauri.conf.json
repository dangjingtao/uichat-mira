{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "UIChat RAG Tester",
  "version": "0.1.0",
  "identifier": "com.tomz.uichat",
  "build": {
    "beforeDevCommand": "pnpm --filter @ui-chat-rag-tester/desktop dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @ui-chat-rag-tester/desktop build",
    "frontendDist": "../desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "UIChat RAG Tester",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../runtime.config.cjs",
      "../server/data",
      "../electron/backend"
    ]
  },
  "plugins": {}
}