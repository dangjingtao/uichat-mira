{
  "name": "@ui-chat-rag-tester/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for UI chat RAG tester.",
  "author": "GitHub Copilot",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:no-backend": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . --no-backend\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "pnpm build && pnpm --filter @ui-chat-rag-tester/server build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/core": "^0.2.10",
    "@assistant-ui/react": "^0.14.14",
    "@assistant-ui/react-ai-sdk": "^1.3.32",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@assistant-ui/react-ui": "^0.2.1",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.17.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.17.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.uichatragtester.desktop",
    "productName": "UI Chat RAG Tester",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-backend/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "electron-backend/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}